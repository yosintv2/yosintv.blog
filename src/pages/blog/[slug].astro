---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar';
import { getPosts, getPost, getCategories, formatDate, stripHtml } from '../../lib/wordpress';

const SVGArrowLeft = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="1em" height="1em" fill="currentColor"><path d="M872 474H286.9l350.2-304c5.6-4.9 2.2-14-5.2-14h-88.5c-3.9 0-7.6 1.4-10.5 3.9L155 487.8a31.96 31.96 0 000 48.3L535.1 866c1.5 1.3 3.3 2 5.2 2h91.5c7.4 0 10.8-9.2 5.2-14L286.9 550H872c4.4 0 8-3.6 8-8v-60c0-4.4-3.6-8-8-8z"/></svg>';
const SVGCalendar = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="1em" height="1em" fill="currentColor"><path d="M880 184H712v-64c0-4.4-3.6-8-8-8h-56c-4.4 0-8 3.6-8 8v64H384v-64c0-4.4-3.6-8-8-8h-56c-4.4 0-8 3.6-8 8v64H144c-17.7 0-32 14.3-32 32v664c0 17.7 14.3 32 32 32h736c17.7 0 32-14.3 32-32V216c0-17.7-14.3-32-32-32zm-40 656H184V460h656v380zM184 392V256h128v48c0 4.4 3.6 8 8 8h56c4.4 0 8-3.6 8-8v-48h256v48c0 4.4 3.6 8 8 8h56c4.4 0 8-3.6 8-8v-48h128v136H184z"/></svg>';
const SVGUser = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="1em" height="1em" fill="currentColor"><path d="M858.5 763.6a374 374 0 00-80.6-119.5 375.63 375.63 0 00-119.5-80.6c-.4-.2-.8-.3-1.2-.5C719.5 518 760 444.7 760 362c0-137-111-248-248-248S264 225 264 362c0 82.7 40.5 156 102.8 201.1-.4.2-.8.3-1.2.5-44.8 18.9-85 46-119.5 80.6a375.63 375.63 0 00-80.6 119.5A371.7 371.7 0 00136 901.8a8 8 0 008 8.2h60c4.4 0 7.9-3.5 8-7.8 2-77.2 33-149.5 87.8-204.3 56.7-56.7 132-87.9 212.2-87.9s155.5 31.2 212.2 87.9C779 752.7 810 825 812 902.2c.1 4.4 3.6 7.8 8 7.8h60a8 8 0 008-8.2c-1-47.8-10.9-94.3-29.5-138.2zM512 534c-45.9 0-89.1-17.9-121.6-50.4S340 407.9 340 362c0-45.9 17.9-89.1 50.4-121.6S466.1 190 512 190s89.1 17.9 121.6 50.4S684 316.1 684 362c0 45.9-17.9 89.1-50.4 121.6S557.9 534 512 534z"/></svg>';
const SVGClock = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="1em" height="1em" fill="currentColor"><path d="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm0 820c-205.4 0-372-166.6-372-372s166.6-372 372-372 372 166.6 372 372-166.6 372-372 372z"/><path d="M686.7 638.6L544.1 535.5V288c0-4.4-3.6-8-8-8H488c-4.4 0-8 3.6-8 8v275.4c0 2.6 1.2 5 3.3 6.5l165.4 120.6c3.6 2.6 8.6 1.8 11.2-1.7l28.6-39c2.6-3.7 1.8-8.5-1.8-11.2z"/></svg>';

export async function getStaticPaths() {
  const allPosts = await getPosts(1, 100);
  return allPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const categories = await getCategories();
const recentPosts = await getPosts(1, 10);
const imageUrl = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
const category = post._embedded?.['wp:term']?.[0]?.[0];
const tags = post._embedded?.['wp:term']?.[1];
---

<Layout title={`${post.title.rendered} - YoSinTV`} description={stripHtml(post.excerpt.rendered)} image={imageUrl}>
  <style>
    .post-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .post-breadcrumb {
      padding: 20px 0;
    }
    .post-breadcrumb a {
      color: #888;
      font-size: 13px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }
    .post-breadcrumb a:hover {
      color: #ff0037;
    }
    .post-layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 60px;
    }
    .post-article {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 16px;
      overflow: hidden;
    }
    .post-header {
      padding: 32px 32px 0;
    }
    .post-category {
      display: inline-block;
      background: #ff0037;
      color: #fff;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 16px;
    }
    .post-title {
      font-size: 32px;
      font-weight: 800;
      color: #fff;
      line-height: 1.3;
      margin-bottom: 16px;
    }
    .post-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 20px;
      color: #888;
      font-size: 14px;
      padding-bottom: 24px;
      border-bottom: 1px solid #2a2a2a;
      margin-bottom: 0;
    }
    .post-meta span {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .post-featured-img {
      width: 100%;
      max-height: 500px;
      object-fit: cover;
    }
    .post-content {
      padding: 32px;
      font-size: 16px;
      line-height: 1.8;
      color: #ddd;
    }
    .post-content :global(h2) {
      font-size: 24px;
      font-weight: 700;
      color: #fff;
      margin: 32px 0 16px;
    }
    .post-content :global(h3) {
      font-size: 20px;
      font-weight: 700;
      color: #fff;
      margin: 28px 0 12px;
    }
    .post-content :global(p) {
      margin-bottom: 20px;
    }
    .post-content :global(a) {
      color: #38b7ee;
    }
    .post-content :global(a:hover) {
      color: #ff0037;
    }
    .post-content :global(img) {
      border-radius: 12px;
      margin: 24px 0;
    }
    .post-content :global(blockquote) {
      border-left: 4px solid #ff0037;
      padding: 16px 24px;
      margin: 24px 0;
      background: rgba(255, 0, 55, 0.05);
      border-radius: 0 12px 12px 0;
      font-style: italic;
      color: #bbb;
    }
    .post-content :global(ul), .post-content :global(ol) {
      padding-left: 24px;
      margin-bottom: 20px;
    }
    .post-content :global(li) {
      margin-bottom: 8px;
    }
    .post-content :global(iframe) {
      width: 100%;
      border-radius: 12px;
      margin: 24px 0;
    }
    .post-tags {
      padding: 0 32px 32px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .post-tag {
      background: #2a2a2a;
      color: #aaa;
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      transition: all 0.2s;
    }
    .post-tag:hover {
      background: #ff0037;
      color: #fff;
    }
    .post-nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      padding: 24px 32px 32px;
      border-top: 1px solid #2a2a2a;
    }
    .post-nav-link {
      background: #252525;
      padding: 16px;
      border-radius: 12px;
      transition: all 0.3s;
    }
    .post-nav-link:hover {
      background: rgba(255, 0, 55, 0.1);
    }
    .post-nav-link.next {
      text-align: right;
    }
    .post-nav-label {
      color: #888;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      margin-bottom: 4px;
    }
    .post-nav-title {
      color: #ddd;
      font-size: 14px;
      font-weight: 600;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .post-nav-link:hover .post-nav-title {
      color: #ff0037;
    }

    @media (max-width: 768px) {
      .post-header { padding: 20px 20px 0; }
      .post-title { font-size: 24px; }
      .post-content { padding: 20px; }
      .post-tags { padding: 0 20px 20px; }
      .post-nav { padding: 20px; grid-template-columns: 1fr; }
    }
    @media (min-width: 900px) {
      .post-layout {
        grid-template-columns: 1fr 320px;
      }
    }
  </style>

  <div class="post-page">
    <div class="post-breadcrumb">
      <a href="/"><span set:html={SVGArrowLeft} /> Back to Home</a>
    </div>

    <div class="post-layout">
      <article class="post-article">
        {imageUrl && (
          <img class="post-featured-img" src={imageUrl} alt={post.title.rendered} loading="eager" />
        )}

        <div class="post-header">
          {category && <span class="post-category">{category.name}</span>}
          <h1 class="post-title" set:html={post.title.rendered} />
          <div class="post-meta">
            <span><span set:html={SVGCalendar} /> {formatDate(post.date)}</span>
            <span><span set:html={SVGUser} /> Admin</span>
            <span><span set:html={SVGClock} /> {Math.ceil(stripHtml(post.content.rendered).split(' ').length / 200)} min read</span>
          </div>
        </div>

        <div class="post-content" set:html={post.content.rendered} />

        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => (
              <span class="post-tag">#{tag.name}</span>
            ))}
          </div>
        )}
      </article>

      <Sidebar categories={categories} recentPosts={recentPosts} client:only="react" />
    </div>
  </div>
</Layout>
