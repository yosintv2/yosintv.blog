---
import Layout from '../layouts/Layout.astro';
import MatchList from '../components/MatchList';
import Sidebar from '../components/Sidebar';

import LatestNews from '../components/LatestNews';
import { config } from '../config';
---

<Layout   title={`Cricket Matches - ${config.site.name}`}>
  <div class="page-wrap">
    <style>
      .page-wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
        background: #fff;
        overflow: hidden;
      }
      .content-sidebar-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 24px 0 60px;
      }
      @media (min-width: 900px) {
        .content-sidebar-layout {
          grid-template-columns: 1fr 320px;
        }
      }
    </style>

    <div class="content-sidebar-layout">
      <div>
        <MatchList
          apiUrl={config.api.cricket}
          title="Cricket Matches"
          isCricket={true}
          client:only="react"
        />
        <div style="background:#fff;text-align:center;padding:8px 0;min-height:60px;display:flex;align-items:center;justify-content:center;">
        <ins class="adsbygoogle"
             style="display:block;background:transparent;"
             data-ad-client={config.ads.google.client}
             data-ad-slot={config.ads.google.slots.betweenMatch}
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        </div>
        <LatestNews client:only="react" />
      </div>
      <Sidebar client:only="react" />
    </div>
  </div>
</Layout>
