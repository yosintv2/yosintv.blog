export async function getStaticPaths() {
  const allCategories = await getCategories();
  return allCategories.map(cat => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const allCategories = await getCategories();
const posts = await getPosts(1, 50, category.id);
const recentPosts = await getPosts(1, 10);
const sectionIcon = category.slug === 'cricket' || category.slug === 't20-world-cup-2026' || category.slug === 'ipl' || category.slug === 'playing-xi'
  ? '🏏'
  : '⚽';
---

<Layout title={`${category.name} - YoSinTV`} description={`Latest ${category.name} news, updates, and coverage on YoSinTV. ${category.description}`}>
  <style>
    .category-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .category-breadcrumb {
      padding: 20px 0;
    }
    .category-breadcrumb a {
      color: #888;
      font-size: 13px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }
    .category-breadcrumb a:hover {
      color: #ff0037;
    }
    .category-header {
      background: linear-gradient(135deg, #1a0a08, #0d0d0d);
      border: 1px solid #2a2a2a;
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 32px;
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .category-icon {
      font-size: 48px;
      width: 80px;
      height: 80px;
      background: rgba(255, 0, 55, 0.1);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .category-info h1 {
      font-size: 28px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 8px;
    }
    .category-info p {
      color: #999;
      font-size: 14px;
      line-height: 1.6;
    }
    .category-count {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255, 0, 55, 0.1);
      color: #ff0037;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      margin-top: 12px;
    }
    .category-layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 60px;
    }
    .category-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .category-empty {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 16px;
      padding: 60px 32px;
      text-align: center;
    }
    .category-empty-icon {
      font-size: 48px;
      margin-bottom: 16px;
    }
    .category-empty h3 {
      color: #fff;
      font-size: 20px;
      margin-bottom: 8px;
    }
    .category-empty p {
      color: #888;
      font-size: 14px;
    }

    @media (min-width: 640px) {
      .category-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 900px) {
      .category-layout { grid-template-columns: 1fr 320px; }
    }
    @media (min-width: 1024px) {
      .category-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

  <div class="category-page">
    <div class="category-breadcrumb">
      <a href="/"><span set:html={SVGArrowLeft} /> Back to Home</a>
    </div>

    <div class="category-header">
      <div class="category-icon">{sectionIcon}</div>
      <div class="category-info">
        <h1>{category.name}</h1>
        {category.description && <p>{category.description}</p>}
        <div class="category-count">
          <span set:html={SVGFire} /> {posts.length} Articles
        </div>
      </div>
    </div>

    <div class="category-layout">
      <div>
        {posts.length > 0 ? (
          <div class="category-grid">
            {posts.map(post => <BlogCard post={post} />)}
          </div>
        ) : (
          <div class="category-empty">
            <div class="category-empty-icon">📝</div>
            <h3>No articles yet</h3>
            <p>Articles in this category will appear here soon.</p>
          </div>
        )}
      </div>

      <Sidebar categories={allCategories} recentPosts={recentPosts} client:only="react" />
    </div>
  </div>
</Layout>
