---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar';
import LeagueGrid from '../components/LeagueGrid';
import LatestNews from '../components/LatestNews';
import { config } from '../config';
---

<Layout title={`${config.site.name} - ${config.site.tagline}`} showTicker={true}>
  <div class="home-wrap">
    <style>
      .home-wrap {
        background: #fff;
      }
      .page-layout {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
      }
      .match-sidebar-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 24px 0 0;
        min-width: 0;
      }
      .match-sidebar-layout > * {
        min-width: 0;
      }

      @media (min-width: 900px) {
        .match-sidebar-layout {
          grid-template-columns: 1fr 320px;
        }
      }
    </style>

    <div class="page-layout">
      <div class="match-sidebar-layout">
        {config.features.showLeagueContainer && <LeagueGrid client:only="react" />}
        <Sidebar client:only="react" />
      </div>

      <div style="background:#fff;text-align:center;padding:0;min-height:0;display:flex;align-items:center;justify-content:center;">
        <ins class="adsbygoogle"
             style="display:block;background:transparent;"
             data-ad-client={config.ads.google.client}
             data-ad-slot={config.ads.google.slots.betweenMatch}
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
      </div>
      <LatestNews client:only="react" />
    </div>
  </div>
</Layout>
