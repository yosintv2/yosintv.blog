---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar';
import LeagueGrid from '../components/LeagueGrid';
import LatestNews from '../components/LatestNews';
import { config } from '../config';
---

<Layout title={`${config.site.name} - ${config.site.tagline}`}>
  <div class="home-wrap">
    <style>
      .home-wrap {
        background: #fff;
      }
      .page-layout {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
        overflow: hidden;
      }
      .match-sidebar-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 24px 0;
      }

      @media (min-width: 900px) {
        .match-sidebar-layout {
          grid-template-columns: 1fr 320px;
        }
      }
    </style>

    <div class="page-layout">
      <div class="match-sidebar-layout">
        {config.features.showLeagueContainer && <LeagueGrid client:only="react" />}
        <Sidebar client:only="react" />
      </div>

      <LatestNews client:only="react" />
    </div>
  </div>
</Layout>
