---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar';
import ShareButtons from '../../components/ShareButtons';
import { config } from '../../config';

interface FootballData {
  event: {
    league: string;
    round: number;
    kick_off_time_utc: string;
    venue: string;
    stadium_capacity: number | null;
    referee: string;
    home_team: { name: string; id: number };
    away_team: { name: string; id: number };
    home_manager: string;
    away_manager: string;
  };
  h2h: { teamDuel: any | null; managerDuel: any | null };
  lineups: {
    home_formation: string;
    away_formation: string;
    home_players: string[];
    away_players: string[];
    home_missing_players: string[];
    away_missing_players: string[];
  };
  pregame_form: any | null;
}

interface Match {
  team1: string;
  team1_logo: string;
  team2: string;
  team2_logo: string;
  league_logo: string | null;
  league: string;
  start: string;
  duration: number;
  details_url: string;
  streaming_url: string;
  event_id: number;
  football_data?: FootballData;
}

export async function getStaticPaths() {
  const paths: Array<{ params: { event_id: string }; props: { match: Match } }> = [];
  try {
    const res = await fetch(config.api.football);
    if (res.ok) {
      const data = await res.json();
      const matches: Match[] = data.matches || data || [];
      for (const m of matches) {
        if (m.event_id) {
          paths.push({ params: { event_id: String(m.event_id) }, props: { match: m } });
        }
      }
    }
  } catch {}
  return paths;
}

const { match } = Astro.props;
const { event_id } = Astro.params;

const fd = match.football_data;
const event = fd?.event;
const lineups = fd?.lineups;

const kickoffDate = event?.kick_off_time_utc
  ? new Date(event.kick_off_time_utc).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })
  : new Date(match.start).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

const kickoffTime = event?.kick_off_time_utc
  ? new Date(event.kick_off_time_utc).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }) + ' UTC'
  : new Date(match.start).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });

const title = `${match.team1} vs ${match.team2} Match Preview: ${match.league} - ${config.site.name}`;
const description = `Match preview for ${match.team1} vs ${match.team2} in the ${match.league}. Lineups, formations, venue details, referee, and head-to-head stats.`;
const image = match.team1_logo;
---

<Layout title={title} description={description} image={image}>
  <style>
    .mp-wrap { max-width: 1200px; margin: 0 auto; padding: 0 10px 60px; }
    .mp-breadcrumb { padding: 6px 0; }
    .mp-breadcrumb a { color: #888; font-size: 11px; display: inline-flex; align-items: center; gap: 4px; text-decoration: none; }
    .mp-layout { display: grid; grid-template-columns: 1fr; gap: 10px; }

    .mp-hero {
      background: linear-gradient(135deg, #0f0c29, #1a1a3e, #24243e);
      border-radius: 10px; padding: 10px 12px 8px; color: #fff; margin-bottom: 10px;
    }
    .mp-hero-top { display: flex; align-items: center; justify-content: center; gap: 5px; margin-bottom: 6px; }
    .mp-hero-top-img { width: 16px; height: 16px; object-fit: contain; }
    .mp-hero-competition { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.65); }
    .mp-hero-teams { display: flex; align-items: center; justify-content: center; gap: 6px; }
    .mp-hero-team { display: flex; flex-direction: column; align-items: center; gap: 1px; flex: 1; }
    .mp-hero-team img { width: 32px; height: 32px; object-fit: contain; }
    .mp-hero-team-name { font-size: 12px; font-weight: 800; }
    .mp-hero-team-sub { display: none; }
    .mp-hero-vs {
      font-size: 11px; font-weight: 900; color: #ff0037;
      background: rgba(255,255,255,0.08); padding: 3px 8px;
      border-radius: 50%; line-height: 1; flex-shrink: 0;
    }
    .mp-hero-meta { text-align: center; margin-top: 6px; padding-top: 6px; border-top: 1px solid rgba(255,255,255,0.05); }
    .mp-hero-meta p { font-size: 10px; color: rgba(255,255,255,0.5); margin: 0; }
    .mp-hero-meta .mp-hero-date { font-size: 11px; color: #fff; font-weight: 600; }
    .mp-hero-meta-row { display: flex; align-items: center; justify-content: center; gap: 6px; margin-top: 4px; flex-wrap: wrap; }
    .mp-hero-chip {
      background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.65);
      padding: 2px 8px; border-radius: 10px; font-size: 9px; font-weight: 500;
    }

    .mp-section {
      background: #fff; border-radius: 8px; padding: 8px 10px; margin-bottom: 8px;
      border: 1px solid #eee;
    }
    .mp-section-title {
      font-size: 12px; font-weight: 800; color: #111; margin-bottom: 6px;
      padding-bottom: 6px; border-bottom: 2px solid #ff0037;
    }

    .mp-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
    .mp-info-card { background: #f8f9fa; border-radius: 6px; padding: 6px 8px; }
    .mp-info-label { font-size: 8px; color: #999; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 1px; }
    .mp-info-value { font-size: 11px; color: #222; font-weight: 600; }
    .mp-info-value small { font-weight: 400; color: #666; font-size: 9px; }

    .mp-lineups { display: grid; grid-template-columns: 1fr; gap: 8px; }
    .mp-lineup-header {
      display: flex; align-items: center; gap: 5px;
      padding: 5px 8px; background: #f8f9fa; border-radius: 5px;
      margin-bottom: 4px;
    }
    .mp-lineup-header img { width: 16px; height: 16px; object-fit: contain; }
    .mp-lineup-header-team { font-size: 11px; font-weight: 700; color: #222; }
    .mp-lineup-header-form { font-size: 9px; color: #ff0037; font-weight: 600; }
    .mp-lineup-grid { display: grid; grid-template-columns: 1fr; gap: 1px; }
    .mp-player-row {
      display: flex; align-items: center; gap: 5px;
      padding: 3px 6px; border-radius: 3px;
      font-size: 11px; color: #444; font-weight: 500;
      background: #fafafa;
    }
    .mp-player-num {
      width: 16px; height: 16px; border-radius: 50%;
      background: #e8e8e8; display: flex; align-items: center;
      justify-content: center; font-size: 8px; font-weight: 700;
      color: #666; flex-shrink: 0;
    }
    .mp-missing { margin-top: 4px; padding: 4px 8px; background: #fff3f3; border-radius: 4px; font-size: 10px; color: #c00; }

    .mp-h2h-card { background: #f8f9fa; border-radius: 6px; padding: 8px; text-align: center; }
    .mp-h2h-null { color: #888; font-size: 11px; font-style: italic; margin: 0; }

    @media (min-width: 640px) {
      .mp-wrap { padding: 0 16px 60px; }
      .mp-hero { border-radius: 12px; padding: 18px 20px 14px; margin-bottom: 14px; }
      .mp-hero-team img { width: 48px; height: 48px; }
      .mp-hero-team-name { font-size: 16px; }
      .mp-hero-team-sub { display: flex; font-size: 10px; }
      .mp-section { padding: 14px 16px; margin-bottom: 12px; border-radius: 10px; }
      .mp-section-title { font-size: 14px; }
      .mp-lineups { grid-template-columns: 1fr 1fr; gap: 12px; }
      .mp-info-grid { gap: 8px; }
      .mp-info-card { padding: 10px; }
    }
    @media (min-width: 900px) {
      .mp-layout { grid-template-columns: 1fr 320px; gap: 20px; }
      .mp-hero { padding: 24px 28px 18px; }
      .mp-hero-team img { width: 60px; height: 60px; }
      .mp-hero-team-name { font-size: 20px; }
    }
  </style>

  <div class="mp-wrap">
    <div class="mp-breadcrumb">
      <a href={config.base || '/'}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="14" height="14" fill="currentColor"><path d="M872 474H286.9l350.2-304c5.6-4.9 2.2-14-5.2-14h-88.5c-3.9 0-7.6 1.4-10.5 3.9L155 487.8a31.96 31.96 0 000 48.3L535.1 866c1.5 1.3 3.3 2 5.2 2h91.5c7.4 0 10.8-9.2 5.2-14L286.9 550H872c4.4 0 8-3.6 8-8v-60c0-4.4-3.6-8-8-8z"/></svg>
        Back to Home
      </a>
    </div>

    <div class="mp-hero">
      <div class="mp-hero-top">
        {match.league_logo && <img src={match.league_logo} alt={match.league} class="mp-hero-top-img" />}
        <span class="mp-hero-competition">{match.league}</span>
      </div>
      <div class="mp-hero-teams">
        <div class="mp-hero-team">
          <img src={match.team1_logo} alt={match.team1} />
          <span class="mp-hero-team-name">{match.team1}</span>
          {event?.home_manager && <span class="mp-hero-team-sub">{event.home_manager}</span>}
        </div>
        <span class="mp-hero-vs">VS</span>
        <div class="mp-hero-team">
          <img src={match.team2_logo} alt={match.team2} />
          <span class="mp-hero-team-name">{match.team2}</span>
          {event?.away_manager && <span class="mp-hero-team-sub">{event.away_manager}</span>}
        </div>
      </div>
      <div class="mp-hero-meta">
        <p class="mp-hero-date">{kickoffDate}</p>
        <p>{kickoffTime}</p>
      </div>
      <div class="mp-hero-meta-row">
        {event?.venue && <span class="mp-hero-chip">{event.venue}</span>}
        {event?.referee && <span class="mp-hero-chip">{event.referee}</span>}
      </div>
    </div>

    <div class="mp-layout">
      <div>
        <div class="mp-section">
          <h2 class="mp-section-title">Match Details</h2>
          <div class="mp-info-grid">
            <div class="mp-info-card">
              <div class="mp-info-label">Competition</div>
              <div class="mp-info-value">{event?.league || match.league}</div>
            </div>
            <div class="mp-info-card">
              <div class="mp-info-label">Round</div>
              <div class="mp-info-value">{event?.round || 'N/A'}</div>
            </div>
            <div class="mp-info-card">
              <div class="mp-info-label">Venue</div>
              <div class="mp-info-value">{event?.venue || 'TBD'}</div>
            </div>
            <div class="mp-info-card">
              <div class="mp-info-label">Referee</div>
              <div class="mp-info-value">{event?.referee || 'TBD'}</div>
            </div>
            <div class="mp-info-card">
              <div class="mp-info-label">Kick-off</div>
              <div class="mp-info-value">{kickoffDate}<br /><small>{kickoffTime}</small></div>
            </div>
          </div>
        </div>

        {lineups && (lineups.home_players?.length > 0 || lineups.away_players?.length > 0) && (
          <div class="mp-section">
            <h2 class="mp-section-title">Predicted Lineups</h2>
            <div class="mp-lineups">
              <div class="mp-lineup-col">
                <div class="mp-lineup-header">
                  <img src={match.team1_logo} alt={match.team1} />
                  <div class="mp-lineup-header-text">
                    <div class="mp-lineup-header-team">{match.team1}</div>
                    {lineups.home_formation && <div class="mp-lineup-header-form">{lineups.home_formation}</div>}
                  </div>
                </div>
                <div class="mp-lineup-grid">
                  {lineups.home_players.map((p: string, i: number) => (
                    <div class="mp-player-row">
                      <span class="mp-player-num">{i + 1}</span>
                      {p}
                    </div>
                  ))}
                </div>
                {lineups.home_missing_players?.length > 0 && (
                  <div class="mp-missing"><strong>Missing:</strong> {lineups.home_missing_players.join(', ')}</div>
                )}
              </div>
              <div class="mp-lineup-col">
                <div class="mp-lineup-header">
                  <img src={match.team2_logo} alt={match.team2} />
                  <div class="mp-lineup-header-text">
                    <div class="mp-lineup-header-team">{match.team2}</div>
                    {lineups.away_formation && <div class="mp-lineup-header-form">{lineups.away_formation}</div>}
                  </div>
                </div>
                <div class="mp-lineup-grid">
                  {lineups.away_players.map((p: string, i: number) => (
                    <div class="mp-player-row">
                      <span class="mp-player-num">{i + 1}</span>
                      {p}
                    </div>
                  ))}
                </div>
                {lineups.away_missing_players?.length > 0 && (
                  <div class="mp-missing"><strong>Missing:</strong> {lineups.away_missing_players.join(', ')}</div>
                )}
              </div>
            </div>
          </div>
        )}

        <div class="mp-section">
          <h2 class="mp-section-title">Head to Head</h2>
          <div class="mp-h2h-card">
            {fd?.h2h?.teamDuel ? (
              <p style="margin:0;font-weight:600;">Previous encounters data available.</p>
            ) : (
              <p class="mp-h2h-null">No recent head-to-head data available between {match.team1} and {match.team2}.</p>
            )}
          </div>
        </div>
        <ShareButtons title={`${match.team1} vs ${match.team2} - ${match.league}`} client:only="react" />
      </div>

      <div>
        <Sidebar client:only="react" />
      </div>
    </div>
  </div>
</Layout>
