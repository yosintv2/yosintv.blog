---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar';
import LatestNews from '../../components/LatestNews';
import ShareButtons from '../../components/ShareButtons';
import { config } from '../../config';

export async function getStaticPaths() {
  try {
    const res = await fetch(config.api.articles);
    if (!res.ok) return [];
    const articles = await res.json();
    return articles.map((a: any) => ({
      params: { slug: a.slug },
      props: { article: a },
    }));
  } catch {
    return [];
  }
}

const { article } = Astro.props;
const { slug } = Astro.params;

const SVGArrowLeft = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="1em" height="1em" fill="currentColor"><path d="M872 474H286.9l350.2-304c5.6-4.9 2.2-14-5.2-14h-88.5c-3.9 0-7.6 1.4-10.5 3.9L155 487.8a31.96 31.96 0 000 48.3L535.1 866c1.5 1.3 3.3 2 5.2 2h91.5c7.4 0 10.8-9.2 5.2-14L286.9 550H872c4.4 0 8-3.6 8-8v-60c0-4.4-3.6-8-8-8z"/></svg>';

const readingTime = article?.content
  ? Math.ceil(article.content.join(' ').split(' ').length / 200)
  : 1;
---

<Layout title={article ? `${article.title} - ${config.site.name}` : `Story - ${config.site.name}`} description={article?.snippet}>
  <style>
    .story-page-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
      overflow: hidden;
    }
    .story-breadcrumb {
      padding: 20px 0;
    }
    .story-breadcrumb a {
      color: #888;
      font-size: 13px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
      transition: color 0.2s;
    }
    .story-breadcrumb a:hover { color: #ff0037; }
    .story-layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 60px;
    }
    .story-article {
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 12px;
      overflow: hidden;
    }
    .story-header { padding: 32px 32px 0; }
    .story-label {
      display: inline-block; background: #ff0037; color: #fff;
      padding: 4px 14px; border-radius: 20px; font-size: 12px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
      margin-bottom: 16px;
    }
    .story-title {
      font-size: 32px; font-weight: 800; color: #222;
      line-height: 1.3; margin-bottom: 16px;
    }
    .story-meta {
      display: flex; flex-wrap: wrap; align-items: center; gap: 20px;
      color: #888; font-size: 14px;
      padding-bottom: 24px; border-bottom: 1px solid #e0e0e0;
    }
    .story-meta span { display: flex; align-items: center; gap: 6px; }
    .story-content {
      padding: 32px; font-size: 16px; line-height: 1.8; color: #444;
    }
    .story-content p { margin-bottom: 20px; }
    .story-tags {
      padding: 0 32px 32px; display: flex; flex-wrap: wrap; gap: 8px;
    }
    .story-tag {
      background: #f0f0f0; color: #666; padding: 6px 14px;
      border-radius: 20px; font-size: 12px; font-weight: 600;
    }
    .story-not-found {
      text-align: center; padding: 60px 0;
    }
    .story-not-found h2 {
      font-size: 24px; color: #222; margin-bottom: 12px;
    }
    .story-not-found a {
      color: #ff0037; text-decoration: none;
    }
    @media (max-width: 768px) {
      .story-header { padding: 20px 20px 0; }
      .story-title { font-size: 24px; }
      .story-content { padding: 20px; }
      .story-tags { padding: 0 20px 20px; }
    }
    @media (min-width: 900px) {
      .story-layout { grid-template-columns: 1fr 320px; }
    }
  </style>

  <div class="story-page-wrap">
    <div class="story-breadcrumb">
      <a href={config.base || '/'}><span set:html={SVGArrowLeft} /> Back to Home</a>
    </div>

    <div class="story-layout">
      <div>
        {article ? (
          <article class="story-article">
            <div class="story-header">
              {article.labels?.[0] && <span class="story-label">{article.labels[0]}</span>}
              <h1 class="story-title">{article.title}</h1>
              <div class="story-meta">
                <span>📅 {article.publishedAt}</span>
                <span>👤 {article.author}</span>
                <span>⏱ {readingTime} min read</span>
              </div>
            </div>
            <div class="story-content">
              {article.content.map((p, i) => <p key={i}>{p}</p>)}
            </div>
            <ShareButtons title={article?.title || 'Article'} client:only="react" />
            {article.labels && article.labels.length > 0 && (
              <div class="story-tags">
                {article.labels.map((tag, i) => (
                  <span key={i} class="story-tag">#{tag}</span>
                ))}
              </div>
            )}
          </article>
        ) : (
          <div class="story-not-found">
            <h2>Article not found</h2>
            <a href={config.base || '/'}>← Back to Home</a>
          </div>
        )}
        <LatestNews client:only="react" />
      </div>

      <Sidebar client:only="react" />
    </div>
  </div>
</Layout>
